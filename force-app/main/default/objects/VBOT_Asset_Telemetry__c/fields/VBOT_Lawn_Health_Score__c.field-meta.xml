    <inlineHelpText>0 - 100. Higher is better.</inlineHelpText>
    <type>Number</type>
    <precision>3</precision>
    <scale>0</scale>
    <required>false</required>
    <unique>false</unique>
    <externalId>false</externalId>
    <trackTrending>false</trackTrending>
    <trackFeedHistory>false</trackFeedHistory>
</CustomField>
